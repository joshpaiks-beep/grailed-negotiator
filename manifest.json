{
  "manifest_version": 3,
  "name": "Grailed Auto-Negotiator",
  "version": "0.1.0",
  "description": "Automatically discover Grailed listings and negotiate offers with rule-based logic.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://www.grailed.com/*",
    "https://*/*",
    "http://localhost/*"
  ],
  "action": {
    "default_title": "Grailed Auto-Negotiator",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.grailed.com/*"
      ],
      "js": [
        "lib/templates.js",
        "lib/negotiator.js",
        "lib/scraper.js",
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
